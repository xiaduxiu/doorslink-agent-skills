{
  "$schema": "https://opencode.ai/config.json",

  // 文件监视器
  "watcher": {
    "ignore": [".idea/**","dist/**", ".git/**", "*.log"]
  },
  // 指定额外的指令文件(与 AGENTS.md 合并)
  "instructions": [],

  // === 权限 ===
  "permission": {
    "write": "allow",
    "edit": "allow",
    "read": "allow",
    "bash": {
      "*": "allow",
      "git *": "ask",
      "npm *": "ask",
      "rm *": "ask"
    }
  }


}
